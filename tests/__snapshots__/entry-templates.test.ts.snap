              pathname: routePattern,
              query: { ...params, ...query },
              asPath: routeUrl,
              locale: locale,
              locales: i18nConfig ? i18nConfig.locales : undefined,
              defaultLocale: currentDefaultLocale,
              domainLocales: domainLocales,
            });
          }
